# Public site URL used for canonical links, Open Graph URLs, sitemap, and robots.txt.
# Set this to your production domain before deploying.
VITE_SITE_URL=https://www.numinas.studio

# Optional CDN base for large video files (Bunny, Cloudflare R2, Mux, etc.)
# Example: https://media.numinas.com
# VITE_VIDEO_CDN_URL=

# After running `npm run encode-videos`, serve the smaller *-web.mp4 encodes.
VITE_VIDEO_USE_WEB_VARIANT=true

# Contact form email (server-only — set in Vercel)
# Option A — Google Workspace App Password (often blocked on Workspace):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=collab@numinas.studio
# SMTP_PASS=<16-char App Password>
#
# Option B — Brevo free SMTP (recommended if Google login keeps failing; no DNS):
# 1. Sign up https://www.brevo.com → verify sender collab@numinas.studio (email link)
# 2. SMTP & API → Generate SMTP key
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=<your Brevo login email>
# SMTP_PASS=<Brevo SMTP key>
#
# CONTACT_TO_EMAIL=collab@numinas.studio
# CONTACT_FROM_EMAIL=Numinas <collab@numinas.studio>
