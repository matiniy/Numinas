# Public site URL used for canonical links, Open Graph URLs, sitemap, and robots.txt.
VITE_SITE_URL=https://www.numinas.studio

# After running `npm run encode-videos`, serve the smaller *-web.mp4 encodes.
VITE_VIDEO_USE_WEB_VARIANT=true

# Contact form email (server-only — set in Vercel)
#
# Recommended on Vercel: Brevo HTTPS API (SMTP ports are often blocked)
# Brevo → SMTP & API → API keys → Generate a new API key
# BREVO_API_KEY=xkeysib-...
# CONTACT_TO_EMAIL=collab@numinas.studio
# CONTACT_FROM_EMAIL=Numinas Studio <collab@numinas.studio>
#
# Optional SMTP fallback (may fail on Vercel with connect/timeout):
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=2525
# SMTP_USER=<Brevo SMTP login>
# SMTP_PASS=<Brevo SMTP key>
